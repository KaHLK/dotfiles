[user]
    name = Kristoffer Kabat
    email = yeah-kris@hotmail.com

[github]
    user = kahlk

[init]
    defaultBranch = main

[alias]
    c = commit
    s = status
    l = log --oneline
    lg = log --oneline --graph

[pull]
    ff = only

[push]
    default = simple

[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true

[core]
    editor = nvim
    hooksPath = $GIT_DIR/hooks

[commit]
    verbose = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = -version:refname


[rerere]
	enabled = true
	autoupdate = true

[worktree]
    useRelativePaths = true
